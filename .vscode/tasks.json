{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Deploy Ding-Tee QA",
            "type": "shell",
            "command": "powershell.exe",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}\\deploy.ps1",
                "-Target", "qa"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Deploy Ding-Tee Storefront",
            "type": "shell",
            "command": "powershell.exe",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}\\deploy.ps1"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "[Watch] Auto-Deploy Ding-Tee Storefront",
            "type": "shell",
            "command": "powershell.exe",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}\\watch-deploy.ps1"
            ],
            "group": "build",
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "echo": false,
                "reveal": "silent",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": {
                "owner": "watch-deploy",
                "pattern": {
                    "regexp": "^NEVER_MATCHES$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "👀 Watching",
                    "endsPattern": "Watcher stopped\\."
                }
            }
        }
    ]
}
